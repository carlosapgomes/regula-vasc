# ── Django ───────────────────────────────────────────────────────────────

DJANGO_SECRET_KEY=change-me-please-use-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL 17) ────────────────────────────────────────────

DATABASE_URL=postgres://regulavasc:regulavasc@localhost:5432/regulavasc

# ── Email ───────────────────────────────────────────────────────────────

# Dev: django.core.mail.backends.console.EmailBackend (default)
# Prod: django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@regulavasc.hospital.org

# ── Cache (dev: LocMemCache, prod: Redis) ───────────────────────────────

# REDIS_URL=redis://localhost:6379/0

# ── Django Q2 (background tasks) ────────────────────────────────────────

# Dev: Django ORM broker (default)
# Prod: Redis broker
# Q2_REDIS_URL=redis://localhost:6379/0

# ── OpenAI (provider padrão para LLM1 e LLM2) ──────────────────────────

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
